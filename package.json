{
  "name": "pinup-popper-browser",
  "version": "0.1.2",
  "license": "GPL-3.0",
  "description": "An app for browsing your Pinup Popper games",
  "private": true,
  "main": "app.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node app",
    "build": "npm run package && npm run copydist && npm run zipdist",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "package": "pkg . --targets node18-win-x64 -o dist/PinUpBrowser.exe",
    "copydist": "copyfiles -f LICENSE README.md config.yml dist",
    "zipdist": "bestzip dist/PinUpBrowser.zip dist/*"
  },
  "bin": "app.js",
  "pkg": {
    "assets": [
      "public/**/*",
      "views/**/*",
      "node_modules/sql.js/dist/*.wasm"
    ],
    "targets": [
      "win"
    ]
  },
  "dependencies": {
    "debug": "^4.4.3",
    "express": "^5.2.1",
    "fast-glob": "^3.2.2",
    "morgan": "^1.7.0",
    "pug": "^3.0.4",
    "serve-favicon": "^2.5.0",
    "sql.js": "^1.13.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.1",
    "bestzip": "^2.2.1",
    "copyfiles": "^2.4.1",
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "app.js",
      "settings.js",
      "routes/**/*.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/doogie2301/pinup-popper-browser"
  },
  "homepage": "https://github.com/doogie2301/pinup-popper-browser",
  "bugs": {
    "url": "https://github.com/doogie2301/pinup-popper-browser/issues"
  }
}